# ──────────────────────────────────────────────────────────────
# DFlash vLLM Environment Configuration
# Copy this file to .env.dflash and edit as needed:
#   cp .env.dflash.example .env.dflash
#
# Or run setup.sh to auto-generate API keys:
#   ./setup-dflash.sh
# ──────────────────────────────────────────────────────────────

# ── Authentication ────────────────────────────────────────────
# HuggingFace token (required to download gated models/drafters)
HF_TOKEN=hf_your_token_here

# vLLM API key for LAN authentication (auto-generated by setup.sh)
VLLM_API_KEY=

# ── Model Configuration ──────────────────────────────────────
# Host path to the target model weights
MODEL_HOST_PATH=/path/to/DFlash-Qwen3.5-27B-Uncensored-NVFP4

# DFlash drafter model (HF repo ID — auto-downloaded on first run)
DFLASH_DRAFTER=z-lab/Qwen3.5-27B-DFlash

# Speculative tokens per draft step (15 for single-stream, 5 for high concurrency)
DFLASH_NUM_SPEC_TOKENS=15

# ── Resource Tuning (DGX Spark GB10 Defaults) ────────────────
MAX_MODEL_LEN=131072
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=131072
